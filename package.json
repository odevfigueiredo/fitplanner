{
  "name": "fitplanner",
  "version": "1.0.0",
  "private": true,
  "description": "FitPlanner monorepo for mobile workout planning, progress tracking, API and web dashboard.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @fitplanner/api",
    "dev:web": "npm run dev -w @fitplanner/web",
    "dev:mobile": "npm run start -w @fitplanner/mobile",
    "build:shared": "npm run build -w @fitplanner/shared",
    "build:api": "npm run build:shared && npm run build -w @fitplanner/api",
    "build:web": "npm run build:shared && npm run build -w @fitplanner/web",
    "build": "npm run build:shared && npm run build -w @fitplanner/api && npm run build -w @fitplanner/web",
    "test": "npm run build:shared && npm run test -w @fitplanner/api",
    "screenshots": "node scripts/capture-screenshots.mjs",
    "screenshots:web": "node scripts/capture-screenshots.mjs --target web",
    "screenshots:mobile": "node scripts/capture-screenshots.mjs --target mobile",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prisma:generate": "npm run prisma:generate -w @fitplanner/api",
    "prisma:migrate": "npm run prisma:migrate -w @fitplanner/api",
    "prisma:studio": "npm run prisma:studio -w @fitplanner/api",
    "seed": "npm run seed -w @fitplanner/api"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "overrides": {
    "expo-constants": "55.0.16",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.4"
  },
  "dependencies": {
    "expo": "55.0.25",
    "expo-constants": "55.0.16",
    "expo-router": "55.0.15",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "playwright": "^1.55.0"
  }
}
